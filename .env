## FoxHunter backend environment variables

# MySQL (SQLAlchemy URL)
# Format: mysql+mysqlconnector://user:password@host:3306/dbname?charset=utf8mb4
MYSQL_URL=mysql+mysqlconnector://root:123456cxn@localhost:3306/foxhunter?charset=utf8mb4

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# App
DEBUG=true
UPLOAD_DIR=uploads

# JWT
JWT_SECRET_KEY=dev-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 可选：UrlMalGuard 自托管 URL 检测服务地址
#URLMALGUARD_BASE=http://localhost:8001

URLHAUS_API_KEY=
VIRUSTOTAL_API_KEY=